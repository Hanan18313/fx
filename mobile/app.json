{
  "expo": {
    "name": "mall-profit-app",
    "slug": "mall-profit-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E53935"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourcompany.mallprofit"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.yourcompany.mallprofit"
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ]
  }
}
